            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"adri.test@example.com\",\n  \"code\": \"1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
