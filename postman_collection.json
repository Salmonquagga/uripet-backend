  "item": [
    {
      "name": "Auth Controller",
      "description": "Endpoints de registro, login y verificación de cuenta.",
      "item": [
        {
          "name": "Register user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registra un usuario nuevo en UriPet. Valida nombre, correo, contraseña y teléfono. Devuelve token JWT, uid y estado de verificación.",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Adri Test\",\n  \"email\": \"adri.test@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"+51999999999\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Login user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Inicia sesión con email y contraseña. Si es exitoso, guarda automáticamente el token JWT en la variable {{token}}.",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"adri.test@example.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login exitoso', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}",
                  "if (json.uid) {",
                  "    pm.collectionVariables.set('uid', json.uid);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "verify"
              ]
            },
            "description": "Verifica la cuenta del usuario usando el código enviado por correo. Requiere Bearer Token.",
